# Jobber OAuth 2.0 Credentials
JOBBER_CLIENT_ID=your_client_id_here
JOBBER_CLIENT_SECRET=your_client_secret_here
JOBBER_REDIRECT_URI=http://127.0.0.1:5000/callback

# Flask
FLASK_SECRET_KEY=change_this_to_a_random_secret_key

# Google Sheets
# The ID from your Google Sheet URL: docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# --- Local development (file-based) ---
# Path to your OAuth client secrets JSON
GOOGLE_CLIENT_SECRETS_FILE=client_secrets.json
# token.json is auto-created after first Google auth

# --- Production / Railway (env var-based) ---
# Paste the full JSON contents of client_secrets.json:
# GOOGLE_CLIENT_SECRETS={"installed":{"client_id":"...","client_secret":"...",...}}
# Paste the full JSON contents of token.json (after running locally first):
# GOOGLE_TOKEN={"token":"...","refresh_token":"...","client_id":"...","client_secret":"...",...}
